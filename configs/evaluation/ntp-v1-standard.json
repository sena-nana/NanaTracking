  },
  "report_template": {
    "path": "../../examples/evaluation/benchmark-report-template-v1.json",
    "sha256": "b018c7262c1c5d5fc4c592a94cb13fe141c2557ede6fa4c695381de516d16cd6"
  },
  "metrics": [
    {"metric_id": "per_signal_error", "unit": "signal-native", "aggregations": ["per-signal", "p50", "p95", "p99"], "required_metadata": ["label confidence", "signal state"]},
    {"metric_id": "per_signal_correlation", "unit": "correlation", "aggregations": ["per-signal"], "required_metadata": ["identity"]},
    {"metric_id": "neutral_jitter", "unit": "signal-native rms", "aggregations": ["per-signal", "p95"], "required_metadata": ["neutral segment"]},
    {"metric_id": "dynamic_response_delay", "unit": "milliseconds", "aggregations": ["per-signal", "p50", "p95", "p99"], "required_metadata": ["capture timestamp"]},
    {"metric_id": "peak_attenuation", "unit": "ratio", "aggregations": ["per-signal", "p50", "p95"], "required_metadata": ["action segment"]},
    {"metric_id": "left_right_asymmetry", "unit": "signal-native error", "aggregations": ["paired-signal", "p95"], "required_metadata": ["anatomical side"]},
    {"metric_id": "identity_neutral_bias", "unit": "signal-native", "aggregations": ["per-identity", "between-identity"], "required_metadata": ["identity", "session"]},
    {"metric_id": "geometry_consistency", "unit": "geometry-native", "aggregations": ["per-structure", "p50", "p95"], "required_metadata": ["camera calibration", "geometry state"]},
    {"metric_id": "state_classification", "unit": "precision-recall", "aggregations": ["per-state", "macro"], "required_metadata": ["observed", "predicted", "occluded", "out-of-frame", "lost"]},
    {"metric_id": "occlusion_recovery_time", "unit": "milliseconds", "aggregations": ["per-region", "p50", "p95", "p99"], "required_metadata": ["occlusion interval"]},
    {"metric_id": "confidence_calibration", "unit": "ece-brier", "aggregations": ["per-signal-family", "per-state"], "required_metadata": ["confidence", "label availability"]},
    {"metric_id": "capture_to_result_latency", "unit": "milliseconds", "aggregations": ["p50", "p95", "p99"], "required_metadata": ["capture timestamp", "produced timestamp"]},
    {"metric_id": "result_age_at_consume", "unit": "milliseconds", "aggregations": ["p50", "p95", "p99"], "required_metadata": ["capture timestamp", "consume timestamp"]},
    {"metric_id": "runtime_resources", "unit": "percent-mib-count", "aggregations": ["cpu", "hottest-thread", "gpu", "vram", "copies", "queue-depth", "long-run-growth"], "required_metadata": ["hardware", "backend", "duration"]},
    {"metric_id": "character_drive_ab_video", "unit": "review", "aggregations": ["blind preference", "failure tags"], "required_metadata": ["video URI", "review protocol"]}
  ],
  "suites": [
